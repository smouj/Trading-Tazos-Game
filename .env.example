# Trading Tazos Game — Environment Configuration
# Copy this file to .env and fill in your values
DATABASE_URL="file:./prisma/dev.db"

# Auth — REQUIRED: generate a strong 64-char random secret
# Example: openssl rand -base64 64
JWT_SECRET="generate-a-random-64-char-secret-here"

# Domain & Branding
NEXT_PUBLIC_DOMAIN=your-domain.com
NEXT_PUBLIC_SITE_NAME="Trading Tazos Game"
NEXT_PUBLIC_CONTACT_EMAIL=support@tradingtazosgame.com

# Deployment
NEXT_PUBLIC_BASE_URL=https://your-domain.com
PORT=3000
WS_PORT=3001
WS_HOST=0.0.0.0

# AdSense — set to "true" to enable Google AdSense (requires approved publisher ID)
NEXT_PUBLIC_ADSENSE_ENABLED=false

# Official transactional email — Hostinger/API bridge
# Keep real values only in the server .env, never in git.
MAIL_FROM_NAME="Trading Tazos Game Support"
MAIL_FROM_EMAIL=support@tradingtazosgame.com
HOSTINGER_EMAIL_API_URL=
HOSTINGER_EMAIL_API_TOKEN=
HOSTINGER_TEMPLATE_WELCOME_ID=
HOSTINGER_TEMPLATE_TRADE_CONFIRMATION_ID=
HOSTINGER_TEMPLATE_PASSWORD_RESET_ID=
HOSTINGER_TEMPLATE_SUPPORT_AUTOREPLY_ID=
