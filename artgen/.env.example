# ttg-artgen — Image API Configuration
# Copy this file to .env and fill in at least ONE key:
#   cp artgen/.env.example .env
#
# Auto-detection order: OpenRouter → xAI → OpenAI
# Force a specific backend: PROVIDER=openrouter

# ─── Option 1: OpenRouter (recommended) ──────────────────
# Get a key at https://openrouter.ai/keys
# Supports: google/gemini-3.1-flash-image-preview (fast)
#           google/gemini-3-pro-image-preview (quality)
#           openai/gpt-5.4-image-2 (best)
OPENROUTER_API_KEY=sk-or-v1-***

# ─── Option 2: xAI Grok ──────────────────────────────────
# XAI_API_KEY=***

# ─── Option 3: OpenAI ────────────────────────────────────
# OPENAI_API_KEY=sk-***

# ─── Backend selection ───────────────────────────────────
# Leave unset to auto-detect (first available key wins)
# PROVIDER=openrouter

# ─── Model override (optional) ───────────────────────────
# IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# ─── Size (optional) ─────────────────────────────────────
# IMAGE_SIZE=1024x1024
