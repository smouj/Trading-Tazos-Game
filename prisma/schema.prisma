generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Franchise {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  color       String      @default("#6366f1")
  icon        String?
  description String?
  mechanic    String?
  collections Collection[]
  tazos       Tazo[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  displayName  String?
  avatarUrl    String?
  credits      Int        @default(100)  // Ingame currency
  emailVerified Boolean   @default(false)
  emailVerifyToken   String?
  emailVerifyExpires DateTime?
  resetToken         String?
  resetTokenExpires  DateTime?
  userTazos    UserTazo[]
  decks        Deck[]
  bagPurchases BagPurchase[]
  creditTransactions CreditTransaction[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Collection {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  franchiseId  String
  franchise    Franchise  @relation(fields: [franchiseId], references: [id])
  year         Int?
  totalTazos   Int        @default(0)
  description  String?
  manufacturer String?
  country      String?
  tazos        Tazo[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Tazo {
  id             String     @id @default(cuid())
  name           String?
  displayName    String?
  slug           String
  franchiseId    String
  franchise      Franchise  @relation(fields: [franchiseId], references: [id])
  collectionId   String
  collection     Collection @relation(fields: [collectionId], references: [id])
  number         String     @default("")
  variant        String?    // megatazo_redondo, megatazo_octogonal, ranura_derecha, ranura_izquierda, gold, black_border
  finish         String?    @default("normal") // normal|matte|glossy|holo|reverse_holo|foil|prismatic|metallic|chrome|gold|rainbow|glitter
  creatureVariant String?   @default("standard") // standard|shiny|shadow|golden|promo|first_edition|misprint
  shinyImageUrl  String?    // alternativa shiny de la criatura
  category       String?    // tazos, supertazos_voladores, supertazos_octogonales, megatazos, holo_3d, mastertazos, caps
  manufacturer   String?
  country        String?
  sourceStatus   String     @default("verified") // verified, partial, pending_visual_check
  combatType     String?
  condition      String     @default("good")
  physicalType   String     @default("cardboard")
  rarity         String     @default("common")
  imageUrl       String?
  skill          String?
  skillDesc      String?
  evolutionFrom  String?
  evolutionTo    String?
  transformStage String?
  transformOf    String?

  // Battle Stats (9-stat system)
  attack    Int @default(50)  // Potencia ofensiva al lanzar
  defense   Int @default(50)  // Capacidad de resistir impactos
  resistance Int @default(50) // Dificultad para ser volteado
  weight    Int @default(50)  // Peso fisico; afecta daño, empuje y estabilidad
  stability Int @default(50)  // Evita vuelcos, desplazamientos y salidas
  spin      Int @default(50)  // Mantiene giro y energia tras caer
  control   Int @default(50)  // Reduce error del lanzamiento
  bounce    Int @default(50)  // Mejora rebotes y golpes encadenados
  precision Int @default(50)  // Mejora punteria y reduce desviacion

  // Role
  role      String?  // attacker, tank, technical, bouncer, heavy, light, balanced, special

  // Stacking
  stackable   Boolean @default(true)
  maxStackOn  Int     @default(1)  // Max tazos this can support on top

  // Game state
  isOwned      Boolean  @default(false)
  battleWins   Int      @default(0)
  battleLosses Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userTazos UserTazo[]
  deckTazos DeckTazo[]
  bagPurchaseTazos BagPurchase[] @relation("BagTazo")
  bagPurchaseBonusTazos BagPurchase[] @relation("BagBonusTazo")

  @@index([franchiseId])
  @@index([collectionId])
  @@index([sourceStatus])
}

model UserTazo {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  tazoId     String
  tazo       Tazo     @relation(fields: [tazoId], references: [id])
  quantity     Int      @default(1)
  isFavorite   Boolean  @default(false)
  obtainedFrom String?  // "bag" | "starter" | "scanner" | null (legacy)
  acquiredAt   DateTime @default(now())
  wear         Int      @default(0)   // 0-100 wear from battle use
  battleCount  Int      @default(0)   // battles participated in

  @@unique([userId, tazoId])
  @@index([userId])
}

model Deck {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  name      String
  isActive  Boolean    @default(false)
  deckTazos DeckTazo[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

model DeckTazo {
  id     String @id @default(cuid())
  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  tazoId String
  tazo   Tazo   @relation(fields: [tazoId], references: [id])

  @@unique([deckId, tazoId])
}

model BattleRecord {
  id            String   @id @default(cuid())
  userId        String?  // User who played this battle
  playerTazos   String   // JSON array of tazo IDs
  opponentTazos String   // JSON array of tazo IDs
  winner        String   // "player" | "opponent" | "draw"
  victoryType   String?
  score         String?  // e.g. "3-1"
  turns         Int      @default(0)
  rounds        Int      @default(0)
  battleLog     String?  // JSON array of battle events
  createdAt     DateTime @default(now())
}

model BagPurchase {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bagType   String   @default("standard") // standard, premium, mega
  cost      Int      @default(50)
  tazoId    String?  // The tazo found inside
  tazo      Tazo?    @relation("BagTazo", fields: [tazoId], references: [id])
  bonusTazo String?  // Occasional 2nd tazo ID
  bonusT    Tazo?    @relation("BagBonusTazo", fields: [bonusTazo], references: [id])
  opened    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int      // positive = earned, negative = spent
  source    String   // "battle_win", "quest", "daily", "bag_purchase", "admin"
  reference String?  // Battle/quest ID reference
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Quest System ───

model Quest {
  id            String     @id @default(cuid())
  title         String     // Display title
  description   String     // What to do
  icon          String     @default("Target")  // Lucide icon name
  category      String     @default("daily")   // daily, weekly, special, beginner
  difficulty    String     @default("easy")    // easy, medium, hard
  requirement   String     // "place_pixels" | "win_battles" | "open_bags" | "collect_tazos" | "create_deck" | "perfect_throw"
  target        Int        @default(1)         // How many to complete
  rewardCredits Int        @default(50)        // Credit reward
  rewardTazoId  String?    // Optional tazo reward
  isActive      Boolean    @default(true)
  orderIndex    Int        @default(0)         // Display order
  expiresAt     DateTime?  // For time-limited quests
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  userQuests    UserQuest[]
}

model UserQuest {
  id          String    @id @default(cuid())
  userId      String
  questId     String
  quest       Quest     @relation(fields: [questId], references: [id])
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  claimed     Boolean   @default(false)  // Reward claimed?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, questId])
  @@index([userId])
}

model Achievement {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String   @default("Award")
  category    String   @default("general")  // general, battle, collection, social
  requirement String   // "collect_count" | "battle_wins" | "credits_earned" | "perfect_throws" | "deck_count" | "bag_count"
  target      Int      @default(1)
  tier        Int      @default(1)  // 1=bronze, 2=silver, 3=gold, 4=platinum
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String    @id @default(cuid())
  userId        String
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  progress      Int       @default(0)
  unlocked      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, achievementId])
  @@index([userId])
}

// ─── Marketplace / Trading System ───

model TradeListing {
  id            String    @id @default(cuid())
  sellerId      String
  userTazoId    String
  price         Int       // Credits
  status        String    @default("active") // active, sold, cancelled
  buyerId       String?
  createdAt     DateTime  @default(now())
  soldAt        DateTime?

  @@index([status])
  @@index([sellerId])
}

model TradeOffer {
  id                String   @id @default(cuid())
  offererId         String   // Who created the offer
  offeredUserTazoId String   // Tazo they're offering
  requestedTazoId   String   // Tazo they want in return
  status            String   @default("pending") // pending, accepted, declined, cancelled
  acceptorId        String?  // Who accepted
  acceptedUserTazoId String? // Tazo the acceptor gave
  createdAt         DateTime @default(now())
  resolvedAt        DateTime?

  @@index([status])
  @@index([offererId])
}
